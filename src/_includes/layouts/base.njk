<!DOCTYPE html>
<html lang="pl">
<head>
  {% include "head.njk" %}
</head>
<body class="{{ bodyClass }}">

  <!-- Custom cursor -->
  <div class="cursor" id="cursor" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>

  <!-- Preloader -->
  <div id="preloader" role="status" aria-label="Ładowanie">
    <div class="pl-panel" id="pl-panel">
      <div class="pl-logo-wrap" id="pl-logo-wrap">
        {% if global.logo.uzyj_obrazu and global.logo.plik %}
          <img src="{{ global.logo.plik }}" alt="{{ global.logo.alt }}" class="pl-logo-img" />
        {% else %}
          <span class="pl-logo-text">{{ global.nazwa_firmy | replace(" | ", " <span class='pl-sep'>|</span> ") | safe }}</span>
        {% endif %}
      </div>
      <div class="pl-spread-line" id="pl-spread-line" aria-hidden="true"></div>
    </div>
  </div>

  {% include "header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <script src="/assets/js/main.js" defer></script>
</body>
</html>
