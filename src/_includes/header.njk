<header class="site-header" id="site-header">
  <a href="/" class="header-logo" aria-label="{{ global.nazwa_firmy }} – strona główna">
    {% if global.logo.uzyj_obrazu and global.logo.plik %}
      <img src="{{ global.logo.plik }}" alt="{{ global.logo.alt }}" class="logo-img" width="160" height="40" />
    {% else %}
      {{ global.nazwa_firmy | replace(" | ", " <span class='logo-sep'>|</span> ") | safe }}
    {% endif %}
  </a>

  <button class="nav-toggle" id="nav-toggle"
    aria-label="Otwórz menu" aria-expanded="false" aria-controls="main-nav">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <nav class="main-nav" id="main-nav" aria-label="Nawigacja główna">
    <ul class="nav-list">
      <li><a href="/"           class="nav-link{% if page.url == '/' %} is-active{% endif %}"><span class="nav-num">01</span>Start</a></li>
      <li><a href="/realizacje" class="nav-link{% if page.url and '/realizacje' in page.url %} is-active{% endif %}"><span class="nav-num">02</span>Realizacje</a></li>
      <li><a href="/o-nas"      class="nav-link{% if page.url and '/o-nas' in page.url %} is-active{% endif %}"><span class="nav-num">03</span>O nas</a></li>
      <li><a href="/kontakt"    class="nav-link nav-link--cta{% if page.url and '/kontakt' in page.url %} is-active{% endif %}">Kontakt</a></li>
    </ul>
  </nav>
</header>
