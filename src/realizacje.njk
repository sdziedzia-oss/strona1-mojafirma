---
layout: base.njk
bodyClass: page-realizacje
permalink: /realizacje/index.html
---
{%- set d = strona_realizacje -%}
{%- set cats = collections.projekty | map("data.kategoria") | unique | sort -%}

<!-- ═══ INTRO ═══ -->
<section class="section rl-intro">
  <div class="ghost-num" aria-hidden="true">02</div>
  <div class="rl-intro-inner">
    <div class="section-label reveal"><span class="ri">02 / Realizacje</span></div>
    <h1 class="rl-h1">
      <div class="reveal"><span class="ri">Archiwum</span></div>
      <div class="reveal reveal-delay-1"><span class="ri"><em>projektów.</em></span></div>
    </h1>
    <p class="rl-intro-sub fade-up">{{ d.podtytul }}</p>
  </div>
  <div class="rl-badge fade-up d2" aria-label="{{ collections.projekty | length }} realizacji w archiwum">
    <span class="rl-badge-num mono">{{ collections.projekty | length }}</span>
    <span class="rl-badge-label mono">realizacji<br>w archiwum</span>
  </div>
</section>

<!-- ═══ ARCHIVE TABLE ═══ -->
<section class="rl-archive" aria-label="Archiwum realizacji">

  <!-- Filters -->
  <div class="rl-filters" role="navigation" aria-label="Filtrowanie po kategorii">
    <button class="rlf-btn is-active" data-f="">Wszystkie</button>
    {% for cat in cats %}
    <button class="rlf-btn" data-f="{{ cat }}">{{ cat }}</button>
    {% endfor %}
  </div>

  <!-- Table head (desktop only) -->
  <div class="rl-thead mono" aria-hidden="true">
    <span class="rl-c-nr">Nr</span>
    <span class="rl-c-rok">Rok</span>
    <span class="rl-c-name">Projekt</span>
    <span class="rl-c-city">Miasto</span>
    <span class="rl-c-type">Rodzaj</span>
  </div>

  <!-- Rows -->
  {% if collections.projekty and collections.projekty.length %}
  <ul class="rl-list" id="rl-list">
    {% for projekt in collections.projekty %}
    <li class="rl-row{% if projekt.data.ma_podstrone !== false %} rl-row--l{% endif %}"
        data-cat="{{ projekt.data.kategoria }}">
      <span class="rl-c-nr mono">{{ loop.index | padStart(2,'0') }}</span>
      <span class="rl-c-rok mono">{{ projekt.data.rok }}</span>
      <div class="rl-c-main">
        {% if projekt.data.ma_podstrone !== false %}
          <a href="{{ projekt.url }}" class="rl-name">
            {{- projekt.data.title -}}<span class="rl-arr" aria-hidden="true">→</span>
          </a>
        {% else %}
          <span class="rl-name rl-name--plain">{{ projekt.data.title }}</span>
        {% endif %}
        {% if projekt.data.opis_krotki %}
        <p class="rl-desc">{{ projekt.data.opis_krotki }}</p>
        {% endif %}
        <p class="rl-mobile-meta mono">{{ projekt.data.rok }} · {{ projekt.data.lokalizacja }} · {{ projekt.data.kategoria }}</p>
      </div>
      <span class="rl-c-city mono">{{ projekt.data.lokalizacja }}</span>
      <span class="rl-c-type mono">{{ projekt.data.kategoria }}</span>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <p class="rl-empty mono">Brak realizacji. Dodaj projekty w panelu CMS.</p>
  {% endif %}

  <div class="rl-foot">
    <span class="mono"><span id="rl-count">{{ collections.projekty | length }}</span> realizacji</span>
    <div class="rl-legend mono">
      <span class="rl-leg-link">Nazwa →</span><span>projekt z opisem</span>
      <span class="rl-leg-plain">Nazwa</span><span>wzmianka w archiwum</span>
    </div>
  </div>

</section>
